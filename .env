# Polymarket Bot Configuration
# CLOB API credentials (api_key, secret, passphrase) are auto-derived from private key

# Required: Your wallet private key (from Polymarket export). Include 0x prefix.
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Required: Your proxy wallet / funder address (the smart contract wallet holding USDC)
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE

# Optional but REQUIRED for gasless redemption (get from Polymarket Settings > API Keys):
# POLYMARKET_RELAYER_API_KEY=your_relayer_api_key
# POLYMARKET_RELAYER_API_KEY_ADDRESS=0x_address_that_owns_the_key

# Optional: Direct Polygon RPC fallback (if relayer not configured). Needs tiny POL for gas.
# POLYGON_RPC=https://polygon-rpc.com

# Trading Settings
MAX_ENTRY_USDC=1.0
MIN_ENTRY_USDC=1.0
ODDS_MIN=0.45
ODDS_MAX=0.55

# Strategy Settings
EMA_PERIOD=50
RSI_PERIOD=14
ATR_PERIOD=14

# Bot Behavior
SCAN_INTERVAL_SECONDS=10
POSITION_CHECK_INTERVAL_SECONDS=30
DEADLINE_SECONDS=180
