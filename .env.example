# =============================================================================
# POLYMARKET BTC 5-MINUTE BOT - CONFIGURATION
# =============================================================================
# 
# CARA SETUP:
# 1. Copy file ini: cp .env.example .env
# 2. Isi hanya 2 variable wajib: POLY_PRIVATE_KEY dan POLY_PROXY_ADDRESS
# 3. API Key, Secret, dan Passphrase akan digenerate OTOMATIS oleh bot
# 4. Ganti BOT_MODE ke LIVE kalau sudah yakin (default: DRY_RUN)
#
# =============================================================================


# =============================================================================
# 🔐 WALLET CREDENTIALS (WAJIB DIISI)
# =============================================================================

# Private key dari wallet Polymarket (EOA signer)
# Cara mendapatkan:
#   - Login ke polymarket.com
#   - Settings → Export Private Key
#   - Copy string yang dimulai dengan 0x...
#   - PASTIKAN TIDAK ADA SPASI DI AWAL/AKHIR
# 
# FORMAT: 0xabc123def456... (64 karakter hex + 0x prefix)
# CONTOH: 0x4f3c2d1e5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2
POLY_PRIVATE_KEY=your_private_key_here


# Proxy / Funder Address (alamat smart contract wallet yang menampung dana)
# Cara mendapatkan:
#   - Login ke polymarket.com
#   - Settings → Account → lihat "Account Address" atau "Proxy Address"
#   - Ini BUKAN alamat MetaMask/EOA mu, tapi alamat proxy wallet Polymarket
#
# FORMAT: 0x... (42 karakter hex)
# CONTOH: 0x6e0c80c90ea6c15917308F820Eac91Ce2724B5b5
POLY_PROXY_ADDRESS=0x_your_proxy_address_here


# =============================================================================
# 🔑 SIGNATURE TYPE (WAJIB DIISI SESUAI WALLET)
# =============================================================================

# Tipe wallet yang kamu pakai di Polymarket:
#   1 = Email/Magic Link wallet (default, paling umum)
#   2 = Browser Extension Proxy (MetaMask via proxy contract)
#   0 = EOA langsung (MetaMask/hardware wallet tanpa proxy)
#
# NOTE: Kalau pakai email login di Polymarket, pilih 1.
#       Kalau pakai MetaMask tapi ada proxy address, pilih 2.
POLY_SIGNATURE_TYPE=1


# =============================================================================
# 🌐 RPC CONFIGURATION (OPTIONAL)
# =============================================================================

# RPC endpoint untuk Polygon Mainnet
# Default menggunakan public RPC, bisa diganti ke private RPC untuk reliability
# CONTOH RPC PROVIDER:
#   - Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   - Infura:  https://polygon-mainnet.infura.io/v3/YOUR_API_KEY
#   - QuickNode: https://your-subdomain.quiknode.pro/YOUR_TOKEN/
#   - Public:  https://polygon-rpc.com (default)
POLYGON_RPC=https://polygon-rpc.com


# =============================================================================
# 🤖 BOT MODE & RISK SETTINGS
# =============================================================================

# Mode operasi bot:
#   DRY_RUN = Simulasi tanpa eksekusi order real (default, aman untuk testing)
#   LIVE    = Trading real dengan dana sungguhan
#
# PASTIKAN sudah test di DRY_RUN minimal 1-2 hari sebelum ganti ke LIVE!
BOT_MODE=LIVE

# Maximum entry amount per trade dalam USD
# Bot akan menggunakan market order FOK sebesar nilai ini
# REKOMENDASI: Mulai dari $1 untuk testing
MAX_ENTRY=1.0

# Odds filter - batas bawah dan atas untuk entry
# Bot HANYA entry kalau odds di range ini (0.45 - 0.55)
# Kenapa: Risk/reward seimbang, tidak beli mahal/jual murah
MIN_ODDS=0.45
MAX_ODDS=0.55

# Confidence threshold (0.0 - 1.0)
# Minimal confidence dari analisis EMA+RSI untuk trigger entry
# 0.6 = 60% confidence minimum
CONFIDENCE_THRESHOLD=0.6


# =============================================================================
# 📊 STRATEGY PARAMETERS (ADVANCED)
# =============================================================================

# Interval candlestick dari Binance untuk analisis teknikal
# 1m = 1 menit, rekomendasi jangan diubah untuk strategy ini
BINANCE_INTERVAL=1m

# Jumlah candlestick history yang di-fetch dari Binance
# Minimal 50 untuk EMA21 + RSI14 yang akurat
BINANCE_KLINE_LIMIT=50

# Trading pair yang dianalisis (jangan diubah untuk BTC bot ini)
TRADING_SYMBOL=BTCUSDT


# =============================================================================
# ⚠️ SAFETY & TIMEOUTS
# =============================================================================

# Maksimal waktu menunggu market resolved sebelum force check (detik)
# Default: 360 detik = 6 menit (market 5m biasanya resolve dalam 1-3 menit)
MAX_RESOLUTION_WAIT=360

# Maksimal umur window sebelum di-skip (detik)
# Kalau sudah lewat 3 menit dari start window, bot skip ke window berikutnya
MAX_WINDOW_AGE=180


# =============================================================================
# 📁 DATA & LOGGING
# =============================================================================

# Path file untuk menyimpan history trades (auto-generated)
TRADES_FILE=data/trades.json

# Maksimal jumlah log yang disimpan di memory (untuk UI)
MAX_LOGS=100


# =============================================================================
# 📝 CATATAN PENTING
# =============================================================================
#
# 1. JANGAN PERNAH commit file .env ini ke GitHub!
#    File .env sudah ada di .gitignore secara default.
#
# 2. Private key adalah kunci akses penuh ke wallet mu.
#    Simpan dengan aman, jangan share ke siapapun.
#
# 3. Proxy address bisa dicek di:
#    https://polymarket.com/settings → Account → Deposit Address
#
# 4. Kalau balance menunjukkan $0 padahal ada dana:
#    - Cek apakah POLY_PROXY_ADDRESS sudah benar
#    - Cek apakah POLY_SIGNATURE_TYPE sesuai (1 untuk email wallet)
#
# 5. Untuk EOA wallet (MetaMask langsung tanpa proxy):
#    - Set POLY_SIGNATURE_TYPE=0
#    - Set POLY_PROXY_ADDRESS sama dengan alamat EOA mu
#    - WAJIB set token allowances manual sebelum trading
#
# 6. Kalau bot error "API credentials failed":
#    - Pastikan private key valid (bisa di-verify di etherscan/polygonscan)
#    - Pastikan proxy address terdaftar di Polymarket
#
# =============================================================================
